# Node modules
node_modules/
**/node_modules/

# Environment variables (development only)
# Allow .env.production for deployment
.env
**/.env
.env.local
**/.env.local
.env*.local

# But allow production env files
!.env.production
!**/.env.production

# Build outputs
dist/
build/
**/.next/
**/out/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Upload directories (images)
uploads/
**/uploads/

# MongoDB data
data/
**/data/

# Cache
.cache/
**/.cache/

# Temporary files
*.tmp
tmp/
temp/

# Package lock files (optional - remove if you want to commit)
# package-lock.json
# yarn.lock
