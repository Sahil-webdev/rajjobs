# MongoDB connection (local or Atlas)
MONGO_URI=mongodb://localhost:27017/rajjobs

# JWT secrets
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_another_long_random_string

# Token expiry settings
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# App
PORT=4000
FRONTEND_URL=http://localhost:3001

# Backend URL (used to generate absolute PDF URLs for local storage)
# In production set this to your Render backend URL
BACKEND_URL=http://localhost:4000

# Cloudinary (OPTIONAL but REQUIRED for production PDF persistence on Render)
# Sign up free at https://cloudinary.com, get credentials from Dashboard > API Keys
# When these are set, PDFs are stored on Cloudinary instead of local disk
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret